{
  "annotations": { "list": [] },
  "editable": true,
  "title": "CRM-hotline-AI — моніторинг",
  "uid": "hotline-main",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Запити за статусом (rate, 5м)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (status) (rate(hotline_requests_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Прийнято всього",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(hotline_requests_total)", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Латентність повного RAG-циклу (p50 / p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(hotline_rag_latency_seconds_bucket[5m])))",
          "legendFormat": "p50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(hotline_rag_latency_seconds_bucket[5m])))",
          "legendFormat": "p95", "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Латентність: пошук vs генерація (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(hotline_retrieval_latency_seconds_bucket[5m])))",
          "legendFormat": "пошук p95", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(hotline_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "LLM p95", "refId": "B"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  }
}
