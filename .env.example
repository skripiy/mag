# --- PostgreSQL ---
POSTGRES_USER=hotline
POSTGRES_PASSWORD=hotline
POSTGRES_DB=hotline
# DSN, який бачить застосунок усередині docker-мережі:
DATABASE_URL=postgresql://hotline:hotline@db:5432/hotline

# --- Ollama ---
OLLAMA_URL=http://ollama:11434
LLM_MODEL=qwen2.5:3b-instruct
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# --- RAG ---
TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=120
# Мінімальна косинусна схожість, нижче якої джерело відкидається (0..1):
MIN_SCORE=0.30

# --- LLM генерація ---
LLM_TEMPERATURE=0.2
LLM_NUM_CTX=4096
LLM_MAX_TOKENS=800

# --- App ---
LOG_LEVEL=INFO
